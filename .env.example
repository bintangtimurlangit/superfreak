PAYLOAD_AUTH_SECRET=YOUR_AUTH_SECRET_HERE
PAYLOAD_SECRET=YOUR_SECRET_HERE
BETTER_AUTH_SECRET=YOUR_SECRET_HERE

DATABASE_URL=mongodb://127.0.0.1/your-database-name
REDIS_URL=redis://redis:6379
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_PAYLOAD_AUTH_URL=http://localhost:3000
# NestJS backend (migration). When set, frontend uses this for /api/* calls via src/lib/api-client.ts.
# Leave unset to keep using Next.js API routes + Payload.
# NEXT_PUBLIC_API_URL=http://localhost:4000
# SuperSlice: server-side only (API route /api/slice proxies to it). Use http://superslice:8000 in Docker.
SUPERSLICE_API_URL=http://localhost:8000

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

RESEND_API_KEY=YOUR_API_HERE
RESEND_FROM_EMAIL=YOUR_RESEND_EMAIL_HERE
RESEND_FROM_NAME=YOUR_EMAIL_NAME_HERE

R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY=YOUR_R2_TOKEN_ACCESS_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_TOKEN_SECRET_KEY
R2_BUCKET_NAME=YOUR_R2_BUCKET_NAME

# Biteship (shipping rates). Get key from https://dashboard.biteship.com/integrations
BITESHIP_API_KEY=YOUR_BITESHIP_API_KEY_HERE
# Optional: origin postal code if not set in Payload Courier Settings
# BITESHIP_ORIGIN_POSTAL_CODE=12440

# Legacy (no longer used for checkout shipping)
RAJAONGKIR_SHIPPING_COST_API=YOUR_API_HERE
RAJAONGKIR_SHIPPING_DELIVERY_API=YOUR_API_HERE

MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY_HERE
MIDTRANS_SERVER_KEY=YOUR_SERVER_KEY_HERE
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=YOUR_CLIENT_KEY_HERE
# Set to "true" for staging/sandbox: backend (verify, notification, initialize) and frontend Snap script use sandbox
MIDTRANS_USE_SANDBOX=false
NEXT_PUBLIC_MIDTRANS_USE_SANDBOX=false

BLOG_API_KEY=YOUR_SECURE_RANDOM_API_KEY_HERE